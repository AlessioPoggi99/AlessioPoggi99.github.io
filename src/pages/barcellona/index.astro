---
// src/pages/index.astro
import BaseLayout from './_layouts/BaseLayout.astro';
import DaySection from './_components/DaySection.astro';
import Dictionary from './_components/Dictionary.astro';
import Guide from './_components/Guide.astro';
import { tripMeta, days } from './_data/trip';
import { dictionary } from './_data/dictionary';
import { guide } from './_data/guide';
---
<BaseLayout title="Barcellona — 4 Giorni">

  <!-- HERO -->
  <div class="hero">
    <p class="hero-label">{tripMeta.label}</p>
    <h1>{tripMeta.title}<br /><em>{tripMeta.titleEm}</em></h1>
    <div class="hero-meta">
      {tripMeta.meta.map(m => <span>{m}</span>)}
    </div>
  </div>

  <!-- NAV -->
  <nav class="day-nav">
    {days.map(day => (
      <>
        <div class={`day-tab${day.number === 1 ? ' active' : ''}`} data-day={day.number} onclick={`showDay(${day.number})`}>
          {day.label}
        </div>
        <div class={`day-tab mobile${day.number === 1 ? ' active' : ''}`} data-day={day.number} onclick={`showDay(${day.number})`}>
          {day.mobileLabel}
        </div>
      </>
    ))}
    <div class="day-tab dict-tab" data-day="dict" onclick="showDay('dict')">
      📖 Dizionario
    </div>
    <div class="day-tab mobile dict-tab" data-day="dict" onclick="showDay('dict')">
      📖 Dizionario
    </div>
    <div class="day-tab guide-tab" data-day="guide" onclick="showDay('guide')">
      🍽 Guida
    </div>
    <div class="day-tab mobile guide-tab" data-day="guide" onclick="showDay('guide')">
      🍽 Guida
    </div>
  </nav>

  <!-- CONTENT -->
  <main class="main">
    {days.map((day, idx) => (
      <DaySection day={day} isFirst={idx === 0} />
    ))}
    <Dictionary sections={dictionary} />
    <Guide sections={guide} />
  </main>

</BaseLayout>
